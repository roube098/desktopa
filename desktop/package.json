{
    "name": "excelor",
    "version": "1.0.0",
    "description": "Excelor — AI-powered document editor",
    "main": "main.js",
    "scripts": {
        "dev:vite": "vite",
        "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
        "build": "vite build && electron-builder --win",
        "bun:vendor": "node scripts/vendor-bun.js",
        "test:unit": "node --test tests/*.test.js",
        "typecheck": "tsc --noEmit",
        "postinstall": "node scripts/vendor-bun.js && electron-builder install-app-deps"
    },
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@assistant-ui/react": "^0.12.15",
        "@assistant-ui/react-markdown": "^0.12.5",
        "@tailwindcss/postcss": "^4.2.1",
        "@types/node": "^25.3.3",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^5.1.4",
        "autoprefixer": "^10.4.27",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^33.0.0",
        "electron-builder": "^25.1.0",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.7.0",
        "vite": "^7.3.1"
    },
    "dependencies": {
        "@openai/codex": "^0.111.0",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tooltip": "^1.2.8",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-tailwindcss": "^3.18.2",
        "form-data": "^4.0.5",
        "framer-motion": "^12.34.5",
        "gray-matter": "^4.0.3",
        "lucide-react": "^0.576.0",
        "node-pty": "^1.1.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^3.5.0",
        "zustand": "^5.0.11"
    }
