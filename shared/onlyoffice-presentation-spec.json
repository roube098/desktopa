                                             "required":  true
                                         },
                                         {
                                             "name":  "y",
                                             "type":  "number",
                                             "description":  "Top position in millimeters.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "width",
                                             "type":  "number",
                                             "description":  "Width in millimeters.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "height",
                                             "type":  "number",
                                             "description":  "Height in millimeters.",
                                             "required":  true
                                         }
                                     ]
                  }
              ]
}
