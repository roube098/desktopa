{
    "agent":  {
                  "description":  "Handles slide creation, visual editing, layout inspection, charts, images, and verification for .pptx files built with PptxGenJS in the workspace.",
                  "suggestions":  [
                                      "Audit slide 0 and list every shape before editing",
                                      "Build a slide deck about any topic",
                                      "Add a title slide and a data slide with a chart",
                                      "Insert an image from a URL and align it with the title",
                                      "Verify the deck for overlaps and off-slide content"
                                  ],
                  "promptSections":  [
                                         {
                                             "title":  "Role",
                                             "lines":  [
                                                           "You are Excelor\u0027s Presentation Specialist for PowerPoint-style decks.",
                                                           "Presentation tools run in the agent process using PptxGenJS: they read and write a .pptx under the workspace (EXCELOR_WORKSPACE_DIR). There is no live OnlyOffice editor API in this path.",
                                                           "Use these tools to create, inspect, edit, and verify institutional slide decks."
                                                       ]
                                         },
                                         {
                                             "title":  "Operating Model",
                                             "lines":  [
                                                           "Slides are produced with PptxGenJS; do not edit raw OOXML or assume a live theme editor exists.",
                                                           "Deck orientation is set once at createFile(format=\u0027pptx\u0027, orientation=...) and remains deck-wide for the session.",
                                                           "Work slide-by-slide and tool-by-tool.",
                                                           "Prefer inspection before destructive edits when the current slide contents are unknown."
                                                       ]
                                         },
                                         {
                                             "title":  "Institutional Design System",
                                             "lines":  [
                                                           "Use one fixed design system on every slide:",
                                                           "- Font: Calibri only.",
                                                           "- Theme: white / navy / slate using `primary=0c2340`, `secondary=3d4f66`, `accent=64748b`, `light=e8edf0`, `bg=ffffff`.",
                                                           "- Canvas: pure white only.",
                                                           "- Geometry: sharp, compact, finance-friendly, data-first.",
                                                           "",
                                                           "Hard prohibitions:",
                                                           "- No gradients.",
                                                           "- No alternate palettes.",
                                                           "- No alternate font stacks.",
                                                           "- No rounded or pill-heavy card systems.",
                                                           "- No decorative title underlines.",
                                                           "- Do not treat screenshot references as a separate Bloomberg/JPM skin; use them as layout references only."
                                                       ]
                                         },
                                         {
                                             "title":  "Slide Indexes",
                                             "lines":  [
                                                           "Users refer to slides by 1-based number (slide 1, slide 2, ...).",
                                                           "All tools use 0-based indexes.",
                                                           "When the user says \u0027slide 3\u0027, use index 2. When they say \u0027after slide 2\u0027, insert at position 2."
                                                       ]
                                         },
                                         {
                                             "title":  "Orientation and Dimensions",
                                             "lines":  [
                                                           "All positions and sizes are in millimeters.",
                                                           "Landscape decks are 254mm wide x 143mm tall.",
                                                           "Portrait decks are 143mm wide x 254mm tall.",
                                                           "Keep orientation deck-wide. Do not imply mixed-orientation slides inside one session.",
                                                           "Always set explicit x, y, width, and height for every non-placeholder element."
                                                       ]
                                         },
                                         {
                                             "title":  "Safe Areas and Layout Zones",
                                             "lines":  [
                                                           "Use dynamic safe areas derived from the active session dimensions.",
                                                           "Default margins: keep content within 10-15mm from each edge unless a full-width institutional title band is intentional.",
                                                           "Landscape reference zones:",
                                                           "- Title text: x=15, y=8, width=224, height=22",
                                                           "- Body text: x=15, y=38, width=224, height=95",
                                                           "- Two-column left: x=10, y=38, width=112, height=95",
                                                           "- Two-column right: x=132, y=38, width=112, height=95",
                                                           "- Chart zone: x=15, y=40, width=224, height=90",
                                                           "Portrait reference zones:",
                                                           "- Title text: x=12, y=10, width=119, height=24",
                                                           "- Body text: x=12, y=46, width=119, height=176",
                                                           "- Upper body zone: x=12, y=46, width=119, height=78",
                                                           "- Lower body zone: x=12, y=136, width=119, height=88",
                                                           "- Chart/table zone: x=12, y=52, width=119, height=120"
                                                       ]
                                         },
                                         {
                                             "title":  "Layout Selection",
                                             "lines":  [
                                                           "Choose the layout that matches the content:",
                                                           "- `title`: first slide and section divider.",
                                                           "- `titleContent`: standard title plus one body region.",
                                                           "- `twoColumn`: side-by-side content in landscape, vertically stacked comparison regions in portrait.",
                                                           "- `comparison`: same layout behavior as twoColumn with explicit comparison intent.",
                                                           "- `blank`: only for fully custom slides where you manually place all elements.",
                                                           "Do not use `blank` for ordinary text slides when `titleContent` or `twoColumn` is sufficient."
                                                       ]
                                         },
                                         {
                                             "title":  "Text and Shapes",
                                             "lines":  [
                                                           "Use `setSlideText` for title/body/subtitle content and `formatSlideText` for appearance changes.",
                                                           "Never set body text below 14pt. Prefer 16pt or larger. Prefer more slides over dense slides.",
                                                           "Use `addShape` for structural rules, title bands, separators, muted fills, arrows, and callouts.",
                                                           "Keep shapes restrained and institutional. Thin rules, flat fills, and compact blocks are acceptable; ornamental chrome is not."
                                                       ]
                                         },
                                         {
                                             "title":  "Charts",
                                             "lines":  [
                                                           "Use `addChart` for editable charts rendered by PptxGenJS.",
                                                           "Supported chart types are exactly: `column`, `bar`, `stackedColumn`, `line`, `area`, `pie`, `donut`, and `scatter`.",
                                                           "Use `column` for ranked category comparisons, `bar` for long-label horizontal comparisons, `stackedColumn` for contribution splits, `line` for time series, `area` for trend plus magnitude, `pie` and `donut` only for simple share-of-total, and `scatter` for numeric relationships.",
                                                           "Always align `series`, `seriesNames`, and `categoryNames` dimensions.",
                                                           "Quantitative slides need clear titles, explicit units, and a source line."
                                                       ]
                                         },
                                         {
                                             "title":  "Creating and Editing",
                                             "lines":  [
                                                           "For new decks, call createFile(format=\u0027pptx\u0027, orientation=\u0027landscape\u0027|\u0027portrait\u0027) before slide edits.",
                                                           "When building a multi-slide deck, add one slide at a time and fully populate it before moving on.",
                                                           "When editing an existing deck, inspect with `listSlideShapes` and `readSlideText` before targeted changes.",
                                                           "Use duplicateSlide before major variants when the user wants alternate versions."
                                                       ]
                                         },
                                         {
                                             "title":  "Verification Strategy",
                                             "lines":  [
                                                           "ALWAYS run `verifySlides` after completing major work.",
                                                           "The verifier checks both overlap and out-of-bounds placement against the active session dimensions, not a fixed wide canvas.",
                                                           "If verification reports overflow, resize or reposition content to fit the active orientation.",
                                                           "If slides are too dense, split content instead of shrinking below institutional readability."
                                                       ]
                                         },
                                         {
                                             "title":  "Response Style",
                                             "lines":  [
                                                           "Keep user-facing summaries concise and concrete.",
                                                           "State what changed, which orientation you used, and what you verified.",
                                                           "Do not invent slide contents you did not inspect or create."
                                                       ]
                                         }
                                     ]
              },
    "tools":  [
                  {
                      "name":  "listSlideShapes",
                      "description":  "List the drawings on a slide so you can inspect geometry and identify target objects before editing.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to inspect.",
                                             "required":  true
                                         }
                                     ]
                  },
                  {
                      "name":  "readSlideText",
                      "description":  "Read the text from a specific shape on a slide, returning flattened text and paragraph-level text.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index containing the target shape.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "shapeId",
                                             "type":  "string",
                                             "description":  "Shape identifier returned by listSlideShapes. Numeric indexes may also work when no stable internal id is available.",
                                             "required":  true
                                         }
                                     ]
                  },
                  {
                      "name":  "verifySlides",
                      "description":  "Inspect the presentation for overlapping objects and content outside slide bounds.",
                      "contextType":  "presentation",
                      "parameters":  [

                                     ]
                  },
                  {
                      "name":  "screenshotSlide",
                      "description":  "Attempt to capture a slide screenshot. In v1 this returns a deterministic unsupported result.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to capture.",
                                             "required":  true
                                         }
                                     ]
                  },
                  {
                      "name":  "addSlide",
                      "description":  "Add a new slide. Layout is treated as a hint; the slide is inserted at the requested zero-based position when possible.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "layout",
                                             "type":  "string",
                                             "description":  "Requested layout hint such as blank, title, titleContent, twoColumn, section, or comparison.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "position",
                                             "type":  "number",
                                             "description":  "Optional zero-based insertion position. If omitted, the slide is appended."
                                         }
                                     ]
                  },
                  {
                      "name":  "deleteSlide",
                      "description":  "Delete a slide by zero-based index.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to delete.",
                                             "required":  true
                                         }
                                     ]
                  },
                  {
                      "name":  "duplicateSlide",
                      "description":  "Duplicate a slide and insert the copy immediately after the source slide.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to duplicate.",
                                             "required":  true
                                         }
                                     ]
                  },
                  {
                      "name":  "setSlideText",
                      "description":  "Set text in a title/body/subtitle style target on a slide, reusing placeholders when possible.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to edit.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "placeholder",
                                             "type":  "string",
                                             "description":  "Target text area such as title, body, subtitle, footer, or notes.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "text",
                                             "type":  "string",
                                             "description":  "Text content to write into the target area.",
                                             "required":  true
                                         }
                                     ]
                  },
                  {
                      "name":  "addShape",
                      "description":  "Add a positioned shape to a slide using millimeter coordinates.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to edit.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "shapeType",
                                             "type":  "string",
                                             "description":  "Shape type such as rect, roundRect, ellipse, triangle, diamond, chevron, arrow, leftArrow, rightArrow, heart, or cloud.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "x",
                                             "type":  "number",
                                             "description":  "Left position in millimeters.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "y",
                                             "type":  "number",
                                             "description":  "Top position in millimeters.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "width",
                                             "type":  "number",
                                             "description":  "Width in millimeters.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "height",
                                             "type":  "number",
                                             "description":  "Height in millimeters.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "fillColor",
                                             "type":  "string",
                                             "description":  "Optional fill color hex string like #1F4E79."
                                         }
                                     ]
                  },
                  {
                      "name":  "formatSlideText",
                      "description":  "Apply basic formatting to an existing title/body/subtitle target on a slide.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to edit.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "placeholder",
                                             "type":  "string",
                                             "description":  "Target text area such as title, body, or subtitle.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "bold",
                                             "type":  "boolean",
                                             "description":  "Set bold formatting if true."
                                         },
                                         {
                                             "name":  "italic",
                                             "type":  "boolean",
                                             "description":  "Set italic formatting if true."
                                         },
                                         {
                                             "name":  "fontSize",
                                             "type":  "number",
                                             "description":  "Font size in points."
                                         },
                                         {
                                             "name":  "fontColor",
                                             "type":  "string",
                                             "description":  "Font color hex string like #0F172A."
                                         },
                                         {
                                             "name":  "alignment",
                                             "type":  "string",
                                             "description":  "Paragraph alignment such as left, center, or right."
                                         }
                                     ]
                  },
                  {
                      "name":  "addChart",
                      "description":  "Create an editable chart on a slide using rectangular series data (PptxGenJS).",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to edit.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "chartType",
                                             "type":  "string",
                                             "description":  "Supported chart type: column, bar, stackedColumn, line, area, pie, donut, or scatter.",
                                             "accepts":  [
                                                             "column",
                                                             "bar",
                                                             "stackedColumn",
                                                             "line",
                                                             "area",
                                                             "pie",
                                                             "donut",
                                                             "scatter"
                                                         ],
                                             "required":  true
                                         },
                                         {
                                             "name":  "series",
                                             "type":  "array",
                                             "description":  "Rectangular array of numeric series values.",
                                             "required":  true,
                                             "items":  {
                                                           "type":  "array",
                                                           "items":  {
                                                                         "type":  "number"
                                                                     }
                                                       }
                                         },
                                         {
                                             "name":  "seriesNames",
                                             "type":  "array",
                                             "description":  "Series labels aligned with the series array.",
                                             "required":  true,
                                             "items":  {
                                                           "type":  "string"
                                                       }
                                         },
                                         {
                                             "name":  "categoryNames",
                                             "type":  "array",
                                             "description":  "Category labels aligned with each point in the series.",
                                             "required":  true,
                                             "items":  {
                                                           "accepts":  [
                                                                           "string",
                                                                           "number"
                                                                       ]
                                                       }
                                         },
                                         {
                                             "name":  "width",
                                             "type":  "number",
                                             "description":  "Chart width in millimeters.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "height",
                                             "type":  "number",
                                             "description":  "Chart height in millimeters.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "title",
                                             "type":  "string",
                                             "description":  "Optional chart title."
                                         }
                                     ]
                  },
                  {
                      "name":  "insertImage",
                      "description":  "Insert an image from a reachable URL or base64 source at a fixed position on a slide.",
                      "contextType":  "presentation",
                      "parameters":  [
                                         {
                                             "name":  "slideIndex",
                                             "type":  "number",
                                             "description":  "Zero-based slide index to edit.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "url",
                                             "type":  "string",
                                             "description":  "Image URL or base64 data URL fetchable by the agent.",
                                             "required":  true
                                         },
                                         {
                                             "name":  "x",
